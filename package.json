{
  "name": "neko-core",
  "version": "0.11.5",
  "description": "Mot chu meo trong terminal, chi muon meo meo - va lam viec. Local-first, config-first, offline-capable.",
  "type": "module",
  "license": "MIT",
  "author": "The Wiii Lab",
  "keywords": [
    "llm",
    "agent",
    "cli",
    "local-first",
    "offline",
    "coding-agent"
  ],
  "bin": {
    "neko": "bin/neko.ts",
    "neko-core": "bin/neko.ts"
  },
  "scripts": {
    "neko": "bun bin/neko.ts",
    "build": "bun scripts/build.ts && dist/neko __uiprobe && bun scripts/input-probe.ts",
      "test": "bun test",
      "typecheck": "bun node_modules/typescript/bin/tsc --noEmit",
      "typecheck:stable": "bun node_modules/typescript5/bin/tsc --noEmit",
      "package:browser": "bun scripts/package-browser-extension.ts",
      "verify": "bun run typecheck:stable && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "typescript": "7.0.1-rc",
    "typescript5": "npm:typescript@^5.9.3",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1"
  }
}

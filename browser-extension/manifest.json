{
  "manifest_version": 3,
  "name": "Neko Browser Bridge",
  "version": "0.4.0",
  "description": "Safely attach one chosen Chrome tab to a local Neko Core session.",
  "minimum_chrome_version": "120",
  "homepage_url": "https://github.com/meiiie/neko-core",
  "key": "",
  "permissions": ["scripting", "storage", "tabGroups", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Attach this tab to Neko",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "incognito": "not_allowed",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src ws://127.0.0.1:* http://127.0.0.1:*"
  }
}
